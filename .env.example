# ============================================================
# Frontend build configuration (Vite — values are PUBLIC, baked
# into the client bundle at build time)
#
# All values are optional: defaults are the current staging
# values, so a build with no .env behaves exactly like staging.
# A per-shop deploy overrides these instead of editing code.
# ============================================================

# Firebase project this deploy talks to (drives the derived
# Cloud Functions base URL — never hardcode *.cloudfunctions.net)
VITE_FIREBASE_PROJECT_ID=b8shield-reseller-app
VITE_FUNCTIONS_REGION=us-central1

# Public domains for this shop
VITE_SHOP_URL=https://shop.b8shield.com
VITE_PORTAL_URL=https://partner.b8shield.com

# Logo used in email templates / SEO (absolute URL)
# VITE_EMAIL_LOGO_URL=

# Stripe publishable key (public by design)
# VITE_STRIPE_PUBLISHABLE_KEY=

# ============================================================
# Cloud Functions runtime configuration lives in
#   functions/.env.<project-id>   (NOT committed)
#
# Supported variables there:
#   SMTP_HOST / SMTP_PORT / SMTP_USER / SMTP_PASS   (required for email)
#   ADMIN_MAINTENANCE_SECRET                        (required, gates ops endpoints)
#   STRIPE_SECRET_KEY / STRIPE_WEBHOOK_SECRET       (via firebase secrets)
#   APP_SHOP_URL / APP_PORTAL_URL                   (public domains)
#   EMAIL_FROM_NAME / EMAIL_FROM_EMAIL / EMAIL_REPLY_TO
#   ADMIN_NOTIFICATION_EMAILS                       (comma-separated)
#   ORDER_NUMBER_PREFIX                             (default B8S)
#   VAT_RATE                                        (default 0.25)
#   SHOP_CURRENCY                                   (default SEK)
#   SHOP_NAME                                       (default B8Shield)
#   CORS_EXTRA_ORIGINS                              (comma-separated)
#   EMAIL_LOGO_URL
# ============================================================
