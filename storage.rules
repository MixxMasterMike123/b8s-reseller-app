rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default deny all access
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Admin check via the `role` custom auth claim, synced from the users
    // collection by the syncAdminClaims maintenance function. (Storage rules
    // cannot read the named Firestore database the app uses, and a hardcoded
    // UID allowlist doesn't generalize to per-customer deploys.)
    //
    // MULTI-TENANT (Phase 3): the claim now also carries `shopId` and
    // `platform` (set by syncAdminClaims). Storage paths are not yet
    // shopId-partitioned, so per-shop write-scoping in storage is deferred to
    // the path restructuring (Phase 0b). Today: any admin (role claim) writes,
    // platform included — matching current single-shop behavior. isPlatform()
    // is exposed now so it's ready when storage paths gain a shop prefix.
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isPlatform() {
      return request.auth != null && request.auth.token.platform == true;
    }

    // Tenant-isolation (Phase B): a write is allowed only by the PLATFORM
    // operator (cross-shop) or by an admin whose trusted `shopId` claim matches
    // the shop segment of the path. This is the storage analogue of the
    // firestore.rules shop scoping — the claim is synced by syncAdminClaims and
    // cannot be spoofed by the client.
    function isAdminOfShop(shopId) {
      return isPlatform() || (isAdmin() && request.auth.token.shopId == shopId);
    }

    // ⚠️ STORAGE RULES MATCHING NOTE (why the LEGACY blocks below are READ-ONLY):
    // In rules_version '2', a path like products/{shopId}/p1/x.jpg matches BOTH
    // the partitioned `match /products/{shopId}/{allPaths=**}` AND the flat
    // `match /products/{allPaths=**}` — and access is granted if EITHER allows
    // it (OR-semantics). If the legacy flat block kept `allow write: if isAdmin()`
    // it would RE-OPEN the cross-shop write hole on the new partitioned paths
    // too (a shop-X admin could write products/shopY/...). So every LEGACY block
    // is READ-ONLY: it only keeps un-migrated files RENDERING during the
    // transition; ALL writes go through the partitioned blocks (every uploader
    // now writes partitioned). After migration (Phase B step 5) delete them.

    // User profile images
    match /users/{userId}/profile.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Order attachments.
    // NOTE (Phase B / tenant-isolation): order attachments are keyed by an
    // unguessable random orderId and the order doc itself carries shopId in
    // Firestore. Read is already gated to the owning customer or an admin, and
    // an admin would need to know the exact orderId to write. This is LOW RISK,
    // so shopId-partitioning the storage path here is DEFERRED — left as-is to
    // avoid breaking the per-order path. Revisit if order attachments ever
    // become enumerable.
    match /orders/{orderId}/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.metadata.userId == request.auth.uid
      );
      allow write: if request.auth != null && (
        isAdmin() ||
        request.resource.metadata.userId == request.auth.uid
      );
    }

    // Product images — PARTITIONED by shopId. New uploads land at
    // products/{shopId}/{productId}/... Public read; write gated to the
    // shop's own admin (or platform).
    match /products/{shopId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOfShop(shopId);
    }

    // LEGACY FLAT PATH (READ-ONLY) — remove after migration (Phase B step 5).
    // Keeps existing pre-partition product images readable during transition.
    // New uploads target products/{shopId}/... Write intentionally omitted (see
    // the matching note above) so this can't re-open cross-shop writes.
    match /products/{allPaths=**} {
      allow read: if true;
    }

    // Storefront branding (logo + hero + gallery images), set via the admin
    // Butik page. PARTITIONED by shopId. Public read so anonymous shoppers see
    // them; write gated to the shop's own admin (or platform).
    match /branding/{shopId}/{allPaths=**} {
      allow read: if true;
      allow write: if isAdminOfShop(shopId);
    }

    // LEGACY FLAT PATH (READ-ONLY) — remove after migration (Phase B step 5).
    // Keeps existing pre-partition branding images readable during transition.
    match /branding/{allPaths=**} {
      allow read: if true;
    }

    // POD print artwork (original + web preview) — PARTITIONED by shopId.
    // Read is GATED (NOT public, unlike product/branding images): print originals
    // are the seller's intellectual property and must not be world-readable. Read +
    // write are both scoped to the shop's own admin (isAdminOfShop includes the
    // isPlatform() bypass). Greenfield path — no legacy flat block.
    //
    // The print_shop role gets NO branch here: it never reads Storage directly. The
    // print-shop callable mints short-lived SIGNED download URLs (Admin SDK), so the
    // printer downloads without any Storage rule grant or custom claim.
    match /pod-artwork/{shopId}/{allPaths=**} {
      allow read: if isAdminOfShop(shopId);
      allow write: if isAdminOfShop(shopId);
    }

    // Content Studio ("Innehållsstudio" add-on) — PARTITIONED by shopId. Holds
    // the admin's own uploaded source images/video/audio (…/uploads/…) and the
    // rendered clips written back by renderSocialVideo (…/renders/…). Read + write
    // are both scoped to the shop's own admin (isAdminOfShop includes the
    // isPlatform() bypass) — these are the shop's private working assets, so read
    // is GATED (not public). Greenfield path — no legacy flat block. Writes are
    // capped at 100 MB and limited to image/video/audio content types (the render
    // callable enforces its own tighter per-file limits server-side).
    // NOTE: size/contentType checks must NOT apply to delete (request.resource
    // is null there), so create/update and delete are granted separately.
    match /content-studio/{shopId}/{allPaths=**} {
      allow read: if isAdminOfShop(shopId);
      allow delete: if isAdminOfShop(shopId);
      allow create, update: if isAdminOfShop(shopId)
        && request.resource.size < 100 * 1024 * 1024
        && (
          request.resource.contentType.matches('image/.*') ||
          request.resource.contentType.matches('video/.*') ||
          request.resource.contentType.matches('audio/.*')
        );
    }

    // Marketing materials — generic (PARTITIONED by shopId).
    // Any authenticated user of the shop can read; write gated to shop admin.
    match /marketing-materials/{shopId}/generic/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdminOfShop(shopId);
    }

    // Customer-specific marketing materials (PARTITIONED by shopId).
    // Customer self-read OR shop admin; write gated to shop admin.
    match /marketing-materials/{shopId}/customers/{customerId}/{fileName} {
      allow read: if request.auth != null && (
        isAdminOfShop(shopId) ||
        request.auth.uid == customerId
      );
      allow write: if isAdminOfShop(shopId);
    }

    // CRM documents for customers (PARTITIONED by shopId).
    match /marketing-materials/{shopId}/customers/{customerId}/crm-documents/{fileName} {
      allow read: if request.auth != null && (
        isAdminOfShop(shopId) ||
        request.auth.uid == customerId
      );
      allow write: if isAdminOfShop(shopId);
    }

    // LEGACY FLAT PATHS (READ-ONLY) — remove after migration (Phase B step 5).
    // Pre-partition marketing materials. Kept readable during transition; new
    // uploads target the partitioned paths above. Writes intentionally omitted.
    match /marketing-materials/generic/{fileName} {
      allow read: if request.auth != null;
    }
    match /marketing-materials/customers/{customerId}/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == customerId
      );
    }
    match /marketing-materials/customers/{customerId}/crm-documents/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == customerId
      );
    }

    // Affiliate invoice storage (PARTITIONED by shopId).
    // Affiliate self-read OR shop admin; write gated to shop admin.
    match /affiliates/{shopId}/{affiliateId}/invoices/{fileName} {
      allow read: if request.auth != null && (
        isAdminOfShop(shopId) ||
        request.auth.uid == affiliateId
      );
      allow write: if isAdminOfShop(shopId);
    }

    // LEGACY FLAT PATH (READ-ONLY) — remove after migration (Phase B step 5).
    match /affiliates/{affiliateId}/invoices/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == affiliateId
      );
    }

    // Admin-only customer documents (PARTITIONED by shopId).
    match /admin-documents/{shopId}/customers/{customerId}/{fileName} {
      allow read, write: if isAdminOfShop(shopId);
    }

    // LEGACY FLAT PATH (READ-ONLY) — remove after migration (Phase B step 5).
    // (Read stays isAdmin during transition so un-migrated admin docs render;
    // the migration closes this. Write omitted — goes to the partitioned path.)
    match /admin-documents/customers/{customerId}/{fileName} {
      allow read: if isAdmin();
    }

    // Page attachments (CMS file upload system) — PARTITIONED by shopId.
    // Public read for published page attachments; write gated to shop admin.
    match /pages/{shopId}/{pageId}/attachments/{fileName} {
      allow read: if true;
      allow write: if isAdminOfShop(shopId);
    }

    // LEGACY FLAT PATH (READ-ONLY) — remove after migration (Phase B step 5).
    match /pages/{pageId}/attachments/{fileName} {
      allow read: if true;
    }
  }
}
