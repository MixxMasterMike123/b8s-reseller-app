rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {
    // Default deny all access
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Admin check via the `role` custom auth claim, synced from the users
    // collection by the syncAdminClaims maintenance function. (Storage rules
    // cannot read the named Firestore database the app uses, and a hardcoded
    // UID allowlist doesn't generalize to per-customer deploys.)
    //
    // MULTI-TENANT (Phase 3): the claim now also carries `shopId` and
    // `platform` (set by syncAdminClaims). Storage paths are not yet
    // shopId-partitioned, so per-shop write-scoping in storage is deferred to
    // the path restructuring (Phase 0b). Today: any admin (role claim) writes,
    // platform included — matching current single-shop behavior. isPlatform()
    // is exposed now so it's ready when storage paths gain a shop prefix.
    function isAdmin() {
      return request.auth != null && request.auth.token.role == 'admin';
    }

    function isPlatform() {
      return request.auth != null && request.auth.token.platform == true;
    }

    // User profile images
    match /users/{userId}/profile.jpg {
      allow read: if true;
      allow write: if request.auth != null && request.auth.uid == userId;
    }

    // Order attachments
    match /orders/{orderId}/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        resource.metadata.userId == request.auth.uid
      );
      allow write: if request.auth != null && (
        isAdmin() ||
        request.resource.metadata.userId == request.auth.uid
      );
    }

    // Product images
    match /products/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Storefront branding (logo + hero + gallery images), set via the admin
    // Butik page. Public read so anonymous shoppers see them; admin-only write.
    match /branding/{allPaths=**} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Marketing materials
    match /marketing-materials/generic/{fileName} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }

    // Customer-specific marketing materials
    match /marketing-materials/customers/{customerId}/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == customerId
      );
      allow write: if isAdmin();
    }

    // CRM documents for customers
    match /marketing-materials/customers/{customerId}/crm-documents/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == customerId
      );
      allow write: if isAdmin();
    }

    // Affiliate invoice storage (admin upload, affiliates read their own)
    match /affiliates/{affiliateId}/invoices/{fileName} {
      allow read: if request.auth != null && (
        isAdmin() ||
        request.auth.uid == affiliateId
      );
      allow write: if isAdmin();
    }

    // Admin-only customer documents
    match /admin-documents/customers/{customerId}/{fileName} {
      allow read, write: if isAdmin();
    }

    // Page attachments (CMS file upload system)
    match /pages/{pageId}/attachments/{fileName} {
      allow read: if true;
      allow write: if isAdmin();
    }
  }
}
