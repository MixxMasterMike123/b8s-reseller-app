rules_version = '2';

// Rules for the NAMED database `b8s-reseller-db` (the only database the app
// uses — client: src/firebase/config.js, functions: functions/src/config/database.ts).
// firebase.json targets this database explicitly; deploying without that
// targeting would update the unused (default) database instead.
//
// Server-only collections (passwordResets, emailVerifications,
// campaignParticipants, campaignRevenueTracking) have NO rules on purpose:
// Cloud Functions use the Admin SDK (bypasses rules) and clients must never
// touch them — they fall through to the default deny at the bottom.

service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions for common checks
    function isAuthenticated() {
      return request.auth != null;
    }

    function isAdmin() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }

    function isActiveUser() {
      return isAuthenticated() &&
        exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.active == true;
    }

    function isUserOrAdmin(userId) {
      return request.auth.uid == userId || isAdmin();
    }

    // ============================================================
    // Users (B2B portal + admin accounts)
    // ============================================================
    match /users/{userId} {
      allow read: if isUserOrAdmin(userId);
      allow create: if isAdmin();
      // Users can update their own profile except role/isActive; admins anything
      allow update: if isUserOrAdmin(userId) &&
        (!isAdmin() ? (
          !("role" in request.resource.data) &&
          !("isActive" in request.resource.data)
        ) : true);
      allow delete: if isAdmin();

      // Per-customer marketing materials (admin document distribution)
      match /marketingMaterials/{materialId} {
        allow read: if isUserOrAdmin(userId);
        allow write: if isAdmin();
      }
    }

    // ============================================================
    // PUBLIC STOREFRONT DATA — anonymous visitors browse the shop
    // ============================================================
    match /products/{productId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /productGroups/{groupId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // CMS pages (legal pages, content pages). Note: drafts are technically
    // readable; keep secrets out of CMS docs.
    match /pages/{pageId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // UI translations, one collection per locale
    match /translations_sv_SE/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /translations_en_GB/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /translations_en_US/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Store identity (shop name, logo, support email) — rendered by the
    // public storefront for anonymous visitors
    match /settings/app {
      allow read: if true;
      allow write: if isAdmin();
    }
    match /settings/{settingId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // ============================================================
    // Orders
    // ============================================================
    match /orders/{orderId} {
      // Single-doc reads are open: the doc ID is an unguessable capability
      // (Stripe payment-intent ID or Firestore auto-ID) and guests must be
      // able to view their confirmation page after paying. Listing is gated.
      allow get: if true;
      // B2B users list their own orders; B2C customers list theirs via
      // account linkage or their verified email; admins list everything.
      allow list: if isAdmin() ||
        (isActiveUser() && resource.data.userId == request.auth.uid) ||
        (isAuthenticated() && resource.data.source == 'b2c' && (
          resource.data.b2cCustomerAuthId == request.auth.uid ||
          (resource.data.b2cCustomerId != null &&
            get(/databases/$(database)/documents/b2cCustomers/$(resource.data.b2cCustomerId)).data.firebaseAuthUid == request.auth.uid) ||
          resource.data.customerInfo.email == request.auth.token.email
        ));
      // B2C orders are created ONLY server-side by the Stripe webhook after
      // signature-verified payment. Clients may only create B2B orders for
      // themselves.
      allow create: if isActiveUser() &&
        request.resource.data.userId == request.auth.uid &&
        (!('source' in request.resource.data) || request.resource.data.source != 'b2c');
      // Users may cancel their own pending/confirmed orders; admins anything
      allow update: if isAdmin() ||
        (isActiveUser() &&
          resource.data.userId == request.auth.uid &&
          request.resource.data.status == 'cancelled' &&
          resource.data.status in ['pending', 'confirmed']);
      allow delete: if isAdmin();
    }

    match /orderStatuses/{statusId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    // ============================================================
    // B2C customer accounts
    // ============================================================
    match /b2cCustomers/{customerId} {
      allow read: if isAuthenticated() && (resource.data.firebaseAuthUid == request.auth.uid || isAdmin());
      // Created at checkout by the (just-authenticated) customer themselves
      allow create: if isAuthenticated() && request.resource.data.firebaseAuthUid == request.auth.uid;
      allow update: if isAuthenticated() && (resource.data.firebaseAuthUid == request.auth.uid || isAdmin());
      allow delete: if isAdmin();
    }

    // ============================================================
    // Affiliate system
    // ============================================================
    // Affiliate doc ID == the affiliate's Firebase Auth uid. Affiliates read
    // their own doc (by uid or by their own verified email — the portal and
    // shop nav query by email). Anonymous discount-code validation goes
    // through the validateDiscountCode callable, never direct reads.
    match /affiliates/{affiliateId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && (
          request.auth.uid == affiliateId ||
          resource.data.email == request.auth.token.email
        ));
      allow write: if isAdmin();
    }

    // Clicks are written ONLY server-side via logAffiliateClickV2 (Admin SDK)
    match /affiliateClicks/{clickId} {
      allow read: if isAdmin();
      allow create: if false;
      allow update, delete: if isAdmin();
    }

    // Public application form (anonymous applicants); only admins read/manage
    match /affiliateApplications/{applicationId} {
      allow create: if request.resource.data.email is string &&
        request.resource.data.email.size() < 200;
      allow read, update, delete: if isAdmin();
    }

    match /affiliatePayouts/{payoutId} {
      allow read: if isAdmin() ||
        (isAuthenticated() && resource.data.affiliateId == request.auth.uid);
      allow write: if isAdmin();
    }

    // ============================================================
    // B2B / admin tooling (marketing, CRM wagons, presence)
    // ============================================================
    match /marketingMaterials/{materialId} {
      allow read: if isActiveUser();
      allow write: if isAdmin();
    }

    match /userWagonSettings/{userId} {
      allow read: if isActiveUser() && (request.auth.uid == userId || isAdmin());
      allow write: if isAdmin();
    }

    match /campaigns/{campaignId} {
      allow read, write: if isAdmin();
    }

    match /adminPresence/{presenceId} {
      allow read, write: if isAdmin();
    }

    match /adminUIDs/{adminUID} {
      allow read, write: if isAdmin();
    }

    // Dining/ambassador wagon CRM data — admin-only internal tooling
    match /activities/{docId} {
      allow read, write: if isAdmin();
    }
    match /followUps/{docId} {
      allow read, write: if isAdmin();
    }
    match /deferredActivities/{docId} {
      allow read, write: if isAdmin();
    }
    match /ambassadorActivities/{docId} {
      allow read, write: if isAdmin();
    }
    match /userMentions/{docId} {
      allow read, write: if isAdmin();
    }
    match /customerDocuments/{docId} {
      allow read, write: if isAdmin();
    }
    match /adminCustomerDocuments/{docId} {
      allow read, write: if isAdmin();
    }
    match /appSettings/{docId} {
      allow read, write: if isAdmin();
    }

    // Default deny for everything else (incl. server-only collections:
    // passwordResets, emailVerifications, campaignParticipants,
    // campaignRevenueTracking)
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
